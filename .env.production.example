# Production Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Groq AI API Key
# ============================================
# Get your free API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# DATABASE (Auto-configured by Railway/Render)
# ============================================
# Railway/Render will automatically set this
# If using external database, set manually:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# OPTIONAL: Custom Configuration
# ============================================

# CORS Origins (comma-separated)
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# API Port (default: 8000)
# PORT=8000

# Log Level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# These go in Vercel environment variables:
# VITE_API_URL=https://your-backend.railway.app
# VITE_WS_URL=wss://your-backend.railway.app
# VITE_MAPBOX_TOKEN=your_mapbox_token (optional, for maps)
